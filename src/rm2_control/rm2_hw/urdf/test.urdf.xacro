<?xml version="1.0"?>
<robot name="test_joint" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <link name="joint_link">
    <visual>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.3" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </inertial>
  </link>

  <joint name="right_front_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="joint_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    
    <limit lower="-1.57" upper="1.57" velocity="3.14" effort="10.0"/>
    
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <ros2_control name="RmHardwareSystem" type="system">
    <hardware>
      <plugin>rm2_hw/RmHardwareSystem</plugin>
    </hardware>
    <joint name="right_front_wheel_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <transmission name="test_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <plugin>transmission_interface/SimpleTransmission</plugin>
      <joint name="right_front_wheel_joint" role="actuated">
        <hardwareInterface>rm2_hw/RmHardwareSystem</hardwareInterface>
        <offset>0.0</offset>
      </joint>
      <actuator name="right_front_wheel_motor" role="actuated">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
  </ros2_control>

</robot>