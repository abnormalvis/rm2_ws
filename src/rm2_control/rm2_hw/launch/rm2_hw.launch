<launch>
    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(command 'xacro /home/ch/rm2_ws/src/rm2_control/rm2_hw/urdf/test.urdf.xacro')"/>
        <param name="use_sim_time" value="true"/>
    </node>
    <!-- <node pkg="rm2_hw" exec="rm2_hw" output="screen">
        <param name="robot_description" value="$(command 'xacro /home/ch/rm2_ws/src/rm2_control/rm2_hw/urdf/test.urdf.xacro')"/>
        <param from="$(find-pkg-share rm2_hw)/config/actuator_coefficient.yaml"/>
        <param from="$(find-pkg-share rm2_hw)/config/hw_config_template.yaml"/>
        <param from="$(find-pkg-share rm2_hw)/config/controller.yaml"/>
    </node> -->
    <node pkg="controller_manager" exec="ros2_control_node" output="screen">
        <!-- <param name="robot_description" value="$(command 'xacro /home/ch/rm2_ws/src/rm2_control/rm2_hw/urdf/test.urdf.xacro')"/> -->
        <param from="$(find-pkg-share rm2_hw)/config/actuator_coefficient.yaml"/>
        <param from="$(find-pkg-share rm2_hw)/config/hw_config_template.yaml"/>
        <param from="$(find-pkg-share rm2_hw)/config/controller.yaml"/>
    </node>
</launch>
