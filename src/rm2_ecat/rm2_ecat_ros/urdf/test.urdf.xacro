<?xml version="1.0"?>
<robot name="test_joint" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link">
  </link>

  <link name="test_link">
  </link>

  <joint name="test_joint" type="continuous">
    <parent link="base_link"/>
    <child link="test_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    
    <limit lower="-1e10" upper="1e10" velocity="10.0" effort="5.0"/>
    
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <ros2_control name="RmEcatHardwareInterface" type="system">
    <hardware>
      <plugin>rm2_ecat_ros/RmEcatHardwareInterface</plugin>
    </hardware>
    <joint name="test_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <transmission name="test_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <plugin>transmission_interface/SimpleTransmission</plugin>
      <joint name="test_joint" role="actuated">
        <hardwareInterface>rm2_ecat_ros/RmEcatHardwareInterface</hardwareInterface>
        <mechanical_reduction>19.2032</mechanical_reduction>
        <offset>0.0</offset>
      </joint>
      <actuator name="test_motor" role="actuated">
        <mechanical_reduction>1</mechanical_reduction>
      </actuator>
    </transmission>
  </ros2_control>

</robot>