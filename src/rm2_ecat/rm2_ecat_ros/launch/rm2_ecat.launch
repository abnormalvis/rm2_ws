<launch>
    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(command 'xacro /home/ch/rm2_ws/src/rm2_ecat/rm2_ecat_ros/urdf/test.urdf.xacro')"/>
        <param name="use_sim_time" value="true"/>
    </node>
    <node pkg="controller_manager" exec="ros2_control_node" output="screen" launch-prefix="ethercat_grant">
        <param name="robot_description" value="$(command 'xacro /home/ch/rm2_ws/src/rm2_ecat/rm2_ecat_ros/urdf/test.urdf.xacro')"/>
        <param name="setupFile" value="$(find-pkg-share rm2_ecat_ros)/config/setup.yaml"/>
        <param from="$(find-pkg-share rm2_ecat_ros)/config/controller.yaml"/>
    </node>
</launch>